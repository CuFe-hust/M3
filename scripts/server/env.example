# Server paths and credentials are environment-only. / 服务器路径和凭据只允许来自环境变量。
REPO_ROOT=$HOME/spacers-agent
AGENT_VENV=$HOME/.venvs/agent-env
VLLM_VENV=$HOME/.venvs/vllm-env
MODEL_PATH=/data/models/Qwen3-VL-4B-Instruct
SERVED_MODEL_NAME=qwen3-vl-4b-instruct
QWEN_HOST=127.0.0.1
QWEN_PORT=8000
MAX_MODEL_LEN=16384
GPU_MEMORY_UTILIZATION=0.90
MAX_NUM_SEQS=2
VLLM_PROFILE=bf16-24g
QWEN_API_KEY=local-vllm
QWEN_BASE_URL=http://127.0.0.1:8000/v1
QWEN_MODEL=qwen3-vl-4b-instruct
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=replace-on-server-only
DATASET_ROOT=/data/dataset
OUTPUT_ROOT=/data/outputs/runs
